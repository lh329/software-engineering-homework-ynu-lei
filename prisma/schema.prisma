generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resumes       Resume[]
  apiKeys       ApiKey[]
}

model Resume {
  id            String     @id @default(cuid())
  userId        String
  title         String
  data          Json
  theme         String     @default("modern")
  isPublic      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores        Score[]
}

model Score {
  id            String     @id @default(cuid())
  resumeId      String
  category      String
  score         Float
  feedback      String?
  createdAt     DateTime   @default(now())
  
  resume        Resume     @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id            String     @id @default(cuid())
  userId        String
  key           String     @unique
  name          String
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JDAnalysis {
  id            String     @id @default(cuid())
  userId        String
  jdContent     String
  analysis      Json
  createdAt     DateTime   @default(now())
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}